# OpenAI API (required for LLM experiment runs)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: override default model
OPENAI_MODEL=gpt-4o-mini

# xAI API (required only for Grok teacher distillation data generation)
XAI_API_KEY=xai-your-api-key-here

# Optional: route failed-trace analysis through a trained local QLoRA adapter
USE_STUDENT_ANALYZER=0
