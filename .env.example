# Copy this file to .env and fill in your keys.

# --- LLM Backend (pick one) ---

# xAI Grok-4 (default profile)
XAI_API_KEY=xai-your-xai-api-key-here
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_TIMEOUT=3600
# GROK_TEACHER_MODEL=grok-4

# OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini        # optional model override

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Local Ollama (set base URL; no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Testing ---
# MOCK_LLM=1                       # Use deterministic mock (for CI, no API key needed)

# --- Distillation / local student analyzer ---
# USE_STUDENT_ANALYZER=1
# STUDENT_ADAPTER_PATH=models/failure_analyzer_lora
# HF_TOKEN=hf-your-token-if-the-base-model-is-gated
